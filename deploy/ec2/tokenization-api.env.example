# Reference only -- deploy/ec2/user-data.sh generates the real
# /etc/inline-reidentify/tokenization-api.env from its own CONFIGURE block at boot. Edit that
# block (or the file on the running instance directly, then `systemctl restart tokenization-api`)
# rather than this file.
#
# Same env vars TokenizationHttpServer reads locally -- see README.md's "Standalone tokenization
# service" section.
KEY_SOURCE=KMS
DATA_ENCRYPTION_KEY_CIPHERTEXT_BASE64=
KMS_KEY_ID=
AWS_REGION=
# Normally left unset -- an EC2 instance role (IMDS) is the default credential source and needs
# none of these. Set AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY instead if using a long-lived IAM
# user (e.g. no instance role attached), plus AWS_SESSION_TOKEN too if those are temporary/STS
# credentials rather than a static IAM user's keys. See README.md's "Data encryption key: KMS
# envelope encryption" section.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
CRYPTO_PROVIDER=BCFIPS
CIPHER_ALGORITHM=AES-CBC-CTS
PORT=4051
